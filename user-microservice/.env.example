# Copy to .env and set real values. Do not commit .env.
# For deployment, set these in your platform's environment variables instead.

# Budget and expense microservices must use this same SECRET_KEY for JWT validation.
SECRET_KEY=dde1b0953d35f999ffdb4e55a066547b8ac69ec2415caa1835b865c1a07fa4a4
ALGORITHM=HS256
# Access token lifetime (minutes). Session lasts until token expires or tab is closed if using sessionStorage.
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_TOKEN_EXPIRE_HOURS=1

# Base URL for email links (reset password, verify email)
APP_BASE_URL=http://localhost:8000

# Plaid Link flow (frontend): hosted (preferred) or embedded (fallback)
PLAID_FLOW=hosted

# Render demo app URL (optional): adds Watch demo / Try live demo links on landing
# DEMO_PUBLIC_URL=https://pocketii-demo.onrender.com

# Email: console = log only (dev), smtp = send via SMTP
EMAIL_MODE=console
# SMTP_HOST=localhost
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# Require email verification before login (set to false for local dev to allow unverified logins)
# REQUIRE_EMAIL_VERIFICATION=false

# Rate limiting (requests per minute per IP)
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_MINUTE=5
RATE_LIMIT_API_PER_MINUTE=200
RATE_LIMIT_EXPENSIVE_PER_USER_PER_MINUTE=60

# CORS: * or comma-separated origins (e.g. https://app.example.com)
CORS_ORIGINS=*

# Security headers
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE_SECONDS=31536000
# Optional: override CSP policy string. Use {nonce} placeholder in script-src when setting nonce-based CSP.
# CSP_POLICY=

# Optional: proxy to expense, budget, and investments microservices
# EXPENSE_SERVICE_URL=http://localhost:3001
# BUDGET_SERVICE_URL=http://localhost:3002
# INVESTMENT_SERVICE_URL=http://localhost:3003
# Optional shared internal key used by budget service to write notifications
# INTERNAL_API_KEY=
# Optional downstream service URLs used by background worker jobs
# EXPENSE_SERVICE_INTERNAL_URL=http://localhost:3001
# BUDGET_SERVICE_INTERNAL_URL=http://localhost:3002
# Calendar subscription token URL base (defaults to APP_BASE_URL)
# CALENDAR_TOKEN_BASE_URL=http://localhost:8000
# Provider webhook secrets map (JSON): {"plaid":"secret","teller":"secret"}
# WEBHOOK_SECRETS_JSON={}
# Leave EXPENSE_API_BASE_FRONTEND and BUDGET_API_BASE_FRONTEND unset so the frontend uses same-origin
# and the proxy forwards the Authorization header. Set only if you need the browser to call microservices directly.

# Optional: override DB connection (defaults shown)
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=users_db
