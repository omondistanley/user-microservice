# JWT: must be identical to SECRET_KEY in user-microservice/.env or JWT validation returns 401.
SECRET_KEY=dde1b0953d35f999ffdb4e55a066547b8ac69ec2415caa1835b865c1a07fa4a4
ALGORITHM=HS256
# JWT_ISSUER=user-microservice
# JWT_AUDIENCE=expense-tracker

# PostgreSQL (same or separate DB; schema will be budgets_db)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=budgets_db

# Expense DB used for budget alert spend evaluation
EXPENSE_DB_HOST=localhost
EXPENSE_DB_PORT=5432
EXPENSE_DB_USER=postgres
EXPENSE_DB_PASSWORD=postgres
EXPENSE_DB_NAME=expenses_db

# Internal notification sink (user-microservice)
USER_SERVICE_INTERNAL_URL=http://localhost:8000
INTERNAL_API_KEY=

# CORS: * or comma-separated origins
CORS_ORIGINS=*

# Security headers
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE_SECONDS=31536000
# Optional: override API CSP policy string
# API_CSP_POLICY=
