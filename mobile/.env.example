# Expo / Expo Go — copy to ".env" in this directory (mobile/)
#   cp .env.example .env
#
# The app now auto-detects your Metro host and builds http://<host>:8080 in dev.
# Production / standalone builds default to the hosted gateway when no Metro host exists.
#
# Point at the same API as the web app (hosted):
# EXPO_PUBLIC_GATEWAY_URL=https://pocketii.fly.dev
#
# Local Docker / dev — use your machine's LAN IP and gateway port (not Metro :8081):
# EXPO_PUBLIC_GATEWAY_URL=http://192.168.1.10:8080
EXPO_PUBLIC_GATEWAY_URL=https://pocketii.fly.dev
