# Expo / Expo Go — copy to ".env" in this directory (mobile/)
#   cp .env.example .env
#
# The app now auto-detects your Metro host and builds http://<host>:8080 in dev.
# Keep this override for reliability (physical devices, split networks, custom ports).
# Physical devices cannot use localhost. Use your machine's LAN IP and the gateway port:
EXPO_PUBLIC_GATEWAY_URL=http://192.168.1.10:8080
