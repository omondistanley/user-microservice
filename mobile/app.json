{
  "expo": {
    "name": "pocketii",
    "slug": "pocketii",
    "scheme": "pocketii",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pocketii.app"
    },
    "android": {
      "package": "com.pocketii.app"
    },
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
