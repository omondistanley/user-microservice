# Example: market + news provider secrets for Fly.io (pocketii single image).
#
# The investments service runs in the same machine as the gateway (see deploy/start.sh).
# Fly sets `fly secrets` on the container BEFORE start.sh runs, so all subprocesses inherit them.
#
# Do NOT commit real keys. Copy this file, fill in values, then either:
#
#   fly secrets import --app pocketii < fly-investment-providers.local.env
#
# or set individually:
#
#   fly secrets set FINNHUB_API_KEY=... BENZINGA_API_KEY=... --app pocketii
#
# Names must match investments-microservice/app/core/config.py

# --- Market data (quotes / bars) ---
# ALPACA_API_KEY=
# ALPACA_API_SECRET=
# FINNHUB_API_KEY=
# TWELVEDATA_API_KEY=
# ALPHAVANTAGE_API_KEY=
# FREE_MARKET_API_KEY=

# --- News (recommendations "View details" headlines; Benzinga + Finnhub are wired) ---
# BENZINGA_API_KEY=
# Optional: override order (defaults are also in fly.toml [env])
# NEWS_PROVIDER_ORDER=benzinga,finnhub,alphavantage
# MARKET_DATA_PROVIDER_ORDER=alpaca,finnhub,twelvedata,alphavantage

# --- AI explainer (recommendation narrative) ---
# GROQ_API_KEY=
# BRAVE_API_KEY=
# AI_EXPLAINER_API_KEY=
