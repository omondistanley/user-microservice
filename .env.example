# Root env for Docker Compose (copy to ".env" — Compose loads it automatically for ${VAR} substitution).
#   cp .env.example .env
# Then edit .env; never commit .env.

# ── Required: same value in every service that validates JWT ───────────────
SECRET_KEY=dde1b0953d35f999ffdb4e55a066547b8ac69ec2415caa1835b865c1a07fa4a4
ALGORITHM=HS256
JWT_ISSUER=user-microservice
JWT_AUDIENCE=expense-tracker

# Recommended: shared by user / expense / budget / investments for internal DELETE/purge routes
INTERNAL_API_KEY=local-dev-internal-api-key-change-me

# Browser & mobile clients should use the gateway for /api/v1/* and auth.* User service uses this
# to enable proxy routes and redirects when users hit :8000 directly.
GATEWAY_PUBLIC_URL=http://localhost:8080

# Skip email verification for local testing (register → login immediately)
REQUIRE_EMAIL_VERIFICATION=false

# Postgres (Compose defaults; override if needed)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Optional: CORS, rate limits, API keys — see README "API Keys & External Services"
