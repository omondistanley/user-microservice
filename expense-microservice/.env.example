# JWT: must be identical to SECRET_KEY in user-microservice/.env or JWT validation returns 401.
SECRET_KEY=dde1b0953d35f999ffdb4e55a066547b8ac69ec2415caa1835b865c1a07fa4a4
ALGORITHM=HS256
# JWT_ISSUER=user-microservice
# JWT_AUDIENCE=expense-tracker

# PostgreSQL (same or separate DB; schema will be expenses_db)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=expenses_db

# Receipt storage: local (filesystem) or db (BLOB)
RECEIPT_STORAGE_BACKEND=local
RECEIPT_STORAGE_PATH=receipts

# Rate limiting for POST /api/v1/expenses (per IP per minute)
RATE_LIMIT_EXPENSES_PER_MINUTE=60

# CORS: * or comma-separated origins
CORS_ORIGINS=*

# Security headers
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE_SECONDS=31536000
# Optional: override API CSP policy string
# API_CSP_POLICY=

# Optional shared key for trusted internal endpoints (for example account-delete purge calls).
# INTERNAL_API_KEY=
# Optional user service URL for calendar token validation and internal notifications.
# USER_SERVICE_INTERNAL_URL=http://localhost:8000

# Apple Wallet (Shortcuts) webhook: secret for POST /api/v1/apple-wallet/webhook (X-Webhook-Secret header).
# APPLE_WALLET_WEBHOOK_SECRET=your-secret
# Single-user mode: user_id to attribute webhook transactions to when user_token is not sent.
# APPLE_WALLET_WEBHOOK_USER_ID=1

# Plaid (optional): PLAID_CLIENT_ID, PLAID_SECRET, PLAID_ENV, ENCRYPTION_KEY, PLAID_WEBHOOK_URL, etc.
# Default Link uses only the Transactions product. Set to enable Recurring Transactions (extra Plaid fee):
# PLAID_ENABLE_RECURRING_TRANSACTIONS=false
