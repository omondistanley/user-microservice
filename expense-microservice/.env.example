# JWT: must be identical to SECRET_KEY in user-microservice/.env or JWT validation returns 401.
SECRET_KEY=dde1b0953d35f999ffdb4e55a066547b8ac69ec2415caa1835b865c1a07fa4a4
ALGORITHM=HS256
# JWT_ISSUER=user-microservice
# JWT_AUDIENCE=expense-tracker

# PostgreSQL (same or separate DB; schema will be expenses_db)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=expenses_db

# Receipt storage: local (filesystem) or db (BLOB)
RECEIPT_STORAGE_BACKEND=local
RECEIPT_STORAGE_PATH=receipts

# Rate limiting for POST /api/expenses (per IP per minute)
RATE_LIMIT_EXPENSES_PER_MINUTE=60

# CORS: * or comma-separated origins
CORS_ORIGINS=*
