SECRET_KEY=dde1b0953d35f999ffdb4e55a066547b8ac69ec2415caa1835b865c1a07fa4a4
ALGORITHM=HS256
JWT_ISSUER=user-microservice
JWT_AUDIENCE=expense-tracker

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_TOKEN_EXPIRE_HOURS=1

APP_BASE_URL=http://localhost:8000
EMAIL_MODE=console
REQUIRE_EMAIL_VERIFICATION=false
CORS_ORIGINS=*

SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE_SECONDS=31536000
# Optional override for gateway CSP (defaults are set in app/core/config.py)
# CSP_POLICY=
# Optional override for API CSP used by expense and budget services
# API_CSP_POLICY=

RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_MINUTE=5
RATE_LIMIT_API_PER_MINUTE=200
RATE_LIMIT_EXPENSIVE_PER_USER_PER_MINUTE=60
RATE_LIMIT_EXPENSES_PER_MINUTE=60

# Receipt storage (expense service)
RECEIPT_STORAGE_BACKEND=local
RECEIPT_STORAGE_PATH=/data/receipts

# Optional Plaid (expense service)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
ENCRYPTION_KEY=

# Optional OAuth providers (user service)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=

# Optional market data providers (investments service)
# Order: first healthy provider is used; fallback to next on failure.
# MARKET_DATA_PROVIDER_ORDER=alpaca,finnhub,twelvedata,alphavantage
MARKET_DATA_PROVIDER_ORDER=alpaca,finnhub,twelvedata,alphavantage

# Broker-grade Alpaca data API
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# Legacy free provider (Finnhub-like; prefer explicit FINNHUB_* below)
FREE_MARKET_API_KEY=
FREE_MARKET_BASE_URL=

# Finnhub (free tier: 60 calls/min; see https://finnhub.io/docs/api)
FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# Twelve Data (free tier: 8 req/min, 800/day; see https://twelvedata.com/docs)
TWELVEDATA_API_KEY=
TWELVEDATA_BASE_URL=https://api.twelvedata.com

# Alpha Vantage (free tier: 25 req/day; see https://www.alphavantage.co/support/#api-key)
ALPHAVANTAGE_API_KEY=
ALPHAVANTAGE_BASE_URL=https://www.alphavantage.co

# Quote cache and data quality (investments service)
# Skip provider call if quote age <= this (seconds). Reduces rate-limit usage.
QUOTE_CACHE_MAX_AGE_SECONDS=60
# Log and set data_quality when new quote deviates from last by more than this fraction (e.g. 0.05 = 5%)
MARKET_QUOTE_DEVIATION_PCT=0.05
# Cache provider health status for this many seconds to avoid hammering status endpoints
MARKET_PROVIDER_STATUS_CACHE_SECONDS=60

# Recommendations: max items per run (holdings + universe suggestions); default page size for list API
MAX_RECOMMENDATIONS=100
RECOMMENDATIONS_PAGE_SIZE=20

# Optional AI explainer for recommendations (investments service)
# Tri-provider: groq, brave, generic. Order tried: AI_EXPLAINER_PROVIDER_ORDER.
AI_EXPLAINER_PROVIDER_ORDER=groq,brave,generic
AI_EXPLAINER_API_BASE=
AI_EXPLAINER_API_KEY=
AI_EXPLAINER_MODEL=
AI_EXPLAINER_TIMEOUT_SECONDS=10
AI_EXPLAINER_MAX_NARRATIVE_CHARS=500

# Groq (free tier rate limits; see https://console.groq.com)
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=6
GROQ_MAX_TOKENS=150

# Brave (free credits monthly; see https://brave.com/api)
BRAVE_API_BASE=https://api.search.brave.com/res/v1
BRAVE_API_KEY=
BRAVE_MODEL=brave
BRAVE_TIMEOUT_SECONDS=8

# News pipeline – Benzinga primary, Finnhub/Alpha Vantage supplement (investments service)
# Used for recommendation details and GET /api/v1/news. Leave empty to disable.
NEWS_PROVIDER_ORDER=benzinga,finnhub,alphavantage
BENZINGA_API_KEY=
BENZINGA_BASE_URL=https://api.benzinga.com
NEWS_TIMEOUT_SECONDS=8
NEWS_PAGE_SIZE=20

# Optional shared key for internal budget->user notification writes
INTERNAL_API_KEY=
